# Server
PORT=3000
NODE_ENV=development
FORCE_HTTPS=false

# Frontend origin (comma-separated allowed origins)
CORS_ORIGIN=http://localhost:5173
CORS_ORIGIN=https://lab-managment-two.vercel.app
APP_ORIGIN=http://localhost:5173
CLIENT_URL=http://localhost:5173
# Auth
JWT_ACCESS_SECRET=CHANGE_ME
JWT_ACCESS_EXPIRES=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Database (use either DATABASE_URL or the fields below)
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=your_database_name
DB_SSL=false

# Email
EMAIL_PROVIDER=gmail
EMAIL_FROM=noreply@example.com

# Resend (if EMAIL_PROVIDER=resend)
RESEND_API_KEY=your_resend_api_key

# SMTP (if EMAIL_PROVIDER=gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_SECURE=false

# Stripe Billing
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_STARTER_PRICE_ID=your_starter_price_id
STRIPE_GROWTH_PRICE_ID=your_growth_price_id
STRIPE_ENTERPRISE_PRICE_ID=your_enterprise_price_id
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/subscription?billing=success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/subscription?billing=cancelled
STRIPE_PORTAL_RETURN_URL=http://localhost:5173/subscription
