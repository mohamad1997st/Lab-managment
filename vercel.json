{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm ci --prefix lab-frontend",
  "buildCommand": "npm run build --prefix lab-frontend",
  "outputDirectory": "lab-frontend/dist",
  "rewrites": [
    {
      "source": "/((?!api(?:/|$)).*)",
      "destination": "/index.html"
    }
  ]
}
